AI_PLATFORM_API_KEY=your_api_key_here
AI_PLATFORM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
AI_PLATFORM_MODEL=qwen/qwen3-5-27b

PAPERS_DIR=papers
VECTOR_DB_DIR=vector_db

EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=1500
CHUNK_OVERLAP=250
SEMANTIC_CHUNKING_ENABLED=false
SEMANTIC_CHUNK_MIN_CHARS=700
SEMANTIC_CHUNK_MAX_CHARS=1500
SEMANTIC_CHUNK_SIMILARITY_THRESHOLD=0.55
RETRIEVAL_K=6
RETRIEVAL_FETCH_K=40
MIN_RELEVANCE_SCORE=1.2
MAX_TOKENS=8192
MAX_CONTEXT_CHARS=7000
SHOW_USAGE=false
DEBUG_RETRIEVAL=false
ANSWER_LANGUAGE=vi

# Local SharePoint sync only. GitHub Actions does not access SharePoint.
MS_AUTH_FLOW=device_code
MS_TENANT_ID=your_tenant_id_here
MS_CLIENT_ID=your_client_id_here
# Not required for local device_code SharePoint sync.
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:8400/callback

# Local-only SharePoint settings.
SHAREPOINT_HOSTNAME=yourtenant.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/your-site-name
SHAREPOINT_SITE_ID=your_sharepoint_site_id_here
SHAREPOINT_DRIVE_ID=your_sharepoint_drive_id_here
SHAREPOINT_FOLDER_PATH=/Shared Documents
SHAREPOINT_DOWNLOAD_DIR=sharepoint_downloads
SHAREPOINT_FILE_EXTENSIONS=.pdf

# Web API access control. When REQUIRE_APP_ACCESS_TOKEN=true the /chat,
# /documents and /documents/count endpoints require the header
# X-App-Access-Token: <APP_ACCESS_TOKEN>. GET /, /health, static assets and the
# Teams /api/messages endpoint stay outside this check.
REQUIRE_APP_ACCESS_TOKEN=false
APP_ACCESS_TOKEN=

TEAMS_BOT_APP_ID=your_teams_bot_app_id_here
TEAMS_BOT_APP_PASSWORD=your_teams_bot_app_password_here
TEAMS_BOT_HOST=0.0.0.0
TEAMS_BOT_PORT=3978
PORT=3978

MICROSOFT_APP_ID=your_microsoft_bot_app_id_here
MICROSOFT_APP_PASSWORD=your_microsoft_bot_client_secret_here
MICROSOFT_APP_TYPE=MultiTenant
MICROSOFT_APP_TENANT_ID=your_tenant_id_here

GREENNODE_CLIENT_ID=your_greennode_client_id_here
GREENNODE_CLIENT_SECRET=your_greennode_client_secret_here
AGENTBASE_RUNTIME_ID=your_existing_agentbase_runtime_id_here
AGENTBASE_ENDPOINT_URL=https://your-agentbase-endpoint.example.com
AGENTBASE_RUNTIME_FLAVOR=runtime-s2-general-2x4

ENABLE_AGENTBASE_MEMORY=false
MEMORY_ID=your_agentbase_memory_id_here
MEMORY_STRATEGY_ID=your_agentbase_memory_strategy_id_here
MEMORY_ACTOR_ID=local-user
MEMORY_SEARCH_LIMIT=5
MEMORY_MAX_CONTEXT_CHARS=1200
